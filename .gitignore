# Local .terraform folder (providers and modules)
.terraform/

# .tfstate files (Contains sensitive data and local state)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Configuration variables (Sensitive data)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI Logs
crash.log

# Ignore CLI configuration files
.terraformrc
terraform.rc